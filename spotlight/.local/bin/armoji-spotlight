#!/usr/bin/env python3
# ── armojidots · Spotlight ──────────────────────────────────────────
# A custom launcher built as TWO coordinated windows:
#
#   • search window  — a LAYER-SHELL surface (namespace "spotlight-search").
#     A normal window's corner_radius is clamped by SwayFX to ~0.36×height,
#     so it can't be a true capsule; a layer surface can, because
#     `layer_effects … blur_ignore_transparent` clips the blur to the
#     opaque pixels — i.e. the CSS-drawn capsule (border-radius = half its
#     height). Holds the entry + keyboard focus (ON_DEMAND). Placed by
#     anchors + margins, not by `swaymsg move`.
#   • list window    — a NORMAL floating window (keeps SwayFX's open/close
#     animation), anchored directly below the search bar via `swaymsg move`
#     and growing DOWNWARD as results change. Filled edge-to-edge by one
#     translucent pill so its corner_radius (10) clips its blur cleanly.
#
# The gap between the two windows is real desktop, so it stays crisp. If the
# gtk4-layer-shell binding is missing, the search window falls back to a
# normal floating window (rounded rectangle, no true capsule).
#
# Elephant is the search/data backend (fuzzy apps + usage ranking + calc);
# we own the UI, so every mode gets its own layout — a grid when empty, a
# list when typing, and our own command providers (/power /set /web /keys).
#
# Resident: started once as `armoji-spotlight --daemon` (systemd user
# service); the keybind runs `armoji-spotlight`, which toggles the windows
# via the running instance, so it opens instantly. Closes on Escape, on
# launch, or when focus leaves both windows.

import gi, json, os, signal, subprocess, sys
from urllib.parse import quote
gi.require_version("Gtk", "4.0")
try:
    gi.require_version("Gtk4LayerShell", "1.0")
    from gi.repository import Gtk4LayerShell as LayerShell
except (ValueError, ImportError):
    LayerShell = None   # fall back to a normal floating search window
from gi.repository import Gtk, Gdk, Gio, GLib

APP_ID = "org.armojidots.Spotlight"   # shared app_id; windows differ by title
CONFIG = os.path.expanduser("~/.config/armoji-spotlight")
THEME = os.path.expanduser("~/.config/sway/scripts/theme.sh")
WALLPAPERS = os.path.expanduser("~/Pictures/Wallpapers")
SET_WALLPAPER = os.path.expanduser("~/.config/sway/scripts/wallpaper-pick.sh")
WIDTH = 640
SEARCH_H = 40                         # short bar so radius (20) = half-height = true capsule
GAP = 12                              # desktop gap between the two windows
TOP_FRAC = 0.18                       # search bar anchored this far down output
GRID_COLS = 5
GRID_ROWS = 2
LIST_LIMIT = 8
FOCUS_OUT_CLOSE = True    # close when focus leaves the launcher

PALETTES = ["wallpaper", "ruby", "orange", "dandelion", "emerald",
            "cobalt", "bubblegum", "purpur", "b&w"]


def item(text, subtext, icon, kind, value, icon_px=None):
    # icon_px lets an item override the default list icon size (e.g. wallpaper
    # thumbnails render bigger so you can actually see them)
    return {"text": text, "subtext": subtext, "icon": icon,
            "kind": kind, "value": value, "icon_px": icon_px}


def elephant(providers, query, limit):
    spec = f"{providers};{query};{limit}"
    try:
        out = subprocess.run(["elephant", "query", "--json", spec],
                             capture_output=True, text=True, timeout=2).stdout
    except Exception:
        return []
    items = []
    for line in out.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            it = json.loads(line)["item"]
        except Exception:
            continue
        prov = it.get("provider", "")
        kind = "calc" if prov == "calc" else "launch"
        val = it.get("text", "") if prov == "calc" else it.get("identifier", "")
        items.append(item(it.get("text", ""), it.get("subtext", ""),
                          it.get("icon", ""), kind, val))
    return items


# ── command providers (our own, not elephant) ───────────────────────
def cmd_power(arg):
    opts = [("Lock", "system-lock-screen", "swaylock -f"),
            ("Logout", "system-log-out", "swaymsg exit"),
            ("Suspend", "system-suspend", "systemctl suspend"),
            ("Reboot", "system-reboot", "systemctl reboot"),
            ("Shutdown", "system-shutdown", "systemctl poweroff")]
    a = arg.strip().lower()
    return [item(t, "", ic, "cmd", ex) for t, ic, ex in opts if a in t.lower()]


def cmd_update(arg):
    opts = [
        ("Full System Update", "system-software-update",
         "foot --app-id=float-tui -e yay -Syu"),
        ("Pacman", "system-software-update",
         "foot --app-id=float-tui -e sudo pacman -Syu"),
        ("AUR (yay)", "system-software-update",
         "foot --app-id=float-tui -e yay -Sua"),
        ("Kernel", "org.cachyos.KernelManager", "cachyos-kernel-manager"),
    ]
    a = arg.strip().lower()
    return [item(t, "", ic, "cmd", ex) for t, ic, ex in opts if a in t.lower()]


def cmd_set(arg):
    # two-level: "/set" shows categories; Colors/Tone drill down (fill), while
    # Wi-Fi/Bluetooth run straight away.
    parts = arg.strip().split(None, 1)
    sub = parts[0].lower() if parts else ""
    rest = parts[1].strip().lower() if len(parts) > 1 else ""

    cats = [  # name, match-key, icon, subtext, kind, value
        ("Colors",    "color",     "preferences-desktop-theme",     "", "fill", "/set color "),
        ("Tone",      "tone",      "preferences-desktop-display",   "", "fill", "/set tone "),
        ("Wallpaper", "wallpaper", "preferences-desktop-wallpaper",
         "~/Pictures/Wallpapers", "fill", "/set wallpaper "),
        ("Wi-Fi",     "wifi",      "network-wireless",              "", "cmd",
         "foot --app-id=float-tui -e nmtui"),
        ("Bluetooth", "bluetooth", "bluetooth",                     "", "cmd",
         "foot --app-id=float-tui -e bluetuith"),
        ("Monitors",  "monitors",  "video-display",                 "", "cmd",
         "~/.config/sway/scripts/monitors.sh"),
    ]
    known = {"color", "colors", "tone", "wallpaper", "wall",
             "wifi", "bluetooth", "blue", "monitors", "monitor", "displays"}
    if sub not in known:   # "/set" or a half-typed category → show the menu
        return [item(name, sub_t, icon, kind, val)
                for name, key, icon, sub_t, kind, val in cats
                if sub in name.lower() or sub in key]
    if sub in ("color", "colors"):
        return [item(p, "palette", "preferences-desktop-theme", "cmd",
                     f"{THEME} apply {p}") for p in PALETTES if rest in p.lower()]
    if sub == "tone":
        return [item(t.capitalize(), "intensity", "preferences-desktop-display",
                     "cmd", f"{THEME} tone {t}")
                for t in ("light", "heavy", "loud") if rest in t]
    if sub in ("wallpaper", "wall"):
        return wallpapers(rest)
    if sub == "wifi":
        return [item("Wi-Fi (nmtui)", "", "network-wireless", "cmd",
                     "foot --app-id=float-tui -e nmtui")]
    if sub in ("monitors", "monitor", "displays"):
        return [item("Monitors (nwg-displays)", "", "video-display", "cmd",
                     "~/.config/sway/scripts/monitors.sh")]
    return [item("Bluetooth (bluetuith)", "", "bluetooth", "cmd",
                 "foot --app-id=float-tui -e bluetuith")]


def wallpapers(filter_str):
    # thumbnails from ~/Pictures/Wallpapers; the item icon IS the image path, so
    # make_icon() renders a live thumbnail. Selecting one sets + persists it.
    exts = (".jpg", ".jpeg", ".png", ".webp")
    try:
        files = sorted(f for f in os.listdir(WALLPAPERS)
                       if f.lower().endswith(exts))
    except OSError:
        files = []
    out = []
    for f in files:
        if filter_str and filter_str not in f.lower():
            continue
        path = os.path.join(WALLPAPERS, f)
        out.append(item(os.path.splitext(f)[0], f, path, "cmd",
                        f'{SET_WALLPAPER} "{path}"', icon_px=56))
    return out or [item("No wallpapers found", WALLPAPERS,
                        "image-missing", "noop", "")]


def cmd_web(arg):
    q = arg.strip()
    if not q:
        return [item("Type a query to search the web…", "", "web-browser",
                     "noop", "")]
    # open Zen directly (quote() percent-encodes q, so the URL is shell-safe)
    url = f"https://www.google.com/search?q={quote(q)}"
    return [item(f"Search the web for “{q}”", "google · zen", "web-browser",
                 "cmd", f'zen-browser "{url}"')]


# keybind cheat-sheet (keys, description) — mirrors the sway config
KEYBINDS = [
    ("Win + T",            "Open terminal (foot)"),
    ("Win + E",            "Open file manager (Nemo)"),
    ("Win + W",            "Open web browser (Zen)"),
    ("Win + D",            "Toggle Spotlight launcher"),
    ("Win + Q",            "Close focused window"),
    ("Win + Space",        "Toggle floating"),
    ("Win + F",            "Toggle fullscreen"),
    ("Win + L",            "Lock screen"),
    ("Win + N",            "Toggle notification center"),
    ("Win + R",            "Toggle terminal sidebar"),
    ("Win + Shift + R",    "Toggle Claude Code sidebar"),
    ("Win + Shift + S",    "Screenshot region → clipboard"),
    ("Win + drag",         "Move window (left-drag) / resize (right-drag)"),
    ("Win + 1…0",          "Switch workspace (per-monitor)"),
    ("Win + Shift + 1…0",  "Move window to workspace and follow"),
    ("Win + Alt + 1…0",    "Move whole workspace to slot and follow"),
]


def cmd_keys(arg):
    a = arg.strip().lower()
    rows = sorted(KEYBINDS, key=lambda kb: kb[0].lower())
    hits = [(k, d) for k, d in rows if a in k.lower() or a in d.lower()]
    if not hits:
        return [item("No matching shortcut", "", "dialog-question", "noop", "")]
    return [item(k, d, "input-keyboard", "noop", "") for k, d in hits]


COMMANDS = {"/power": cmd_power, "/set": cmd_set,
            "/web": cmd_web, "/keys": cmd_keys, "/update": cmd_update}


def make_icon(name, px):
    img = Gtk.Image()
    img.set_pixel_size(px)
    if name and name.startswith("/") and os.path.exists(name):
        img.set_from_file(name)
    elif name:
        img.set_from_icon_name(name)
    else:
        img.set_from_icon_name("application-x-executable")
    return img


def swaymsg(cmd):
    subprocess.run(["swaymsg", cmd], capture_output=True)


class Spotlight(Gtk.Application):
    def __init__(self):
        super().__init__(application_id=APP_ID,
                         flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE)
        self.search_win = None
        self.list_win = None
        self.cells = []
        self.sel = 0
        self._was_active = False
        self._closeable = False
        self._css_providers = []

    # ── invocation ───────────────────────────────────────────────────
    def do_command_line(self, cmdline):
        if "--daemon" in cmdline.get_arguments():
            self.hold()
            self.ensure_windows()
            # live theme reload: theme.sh sends SIGUSR1 after regenerating
            # colors.css, so the resident launcher re-reads it without a restart
            GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGUSR1,
                                 self._on_reload)
        else:
            self.toggle()
        return 0

    def _on_reload(self):
        self.load_css()
        return True   # keep the handler installed

    def ensure_windows(self):
        if self.search_win is not None:
            return
        self.load_css()

        # search window — layer-shell surface so it can be a TRUE capsule
        self.search_win = Gtk.ApplicationWindow(application=self)
        self.search_win.set_title("spotlight-search")
        self.search_win.set_decorated(False)
        self.search_win.set_resizable(False)
        self.search_win.add_css_class("spotlight")
        self.search_win.set_hide_on_close(True)
        if LayerShell is not None:
            LayerShell.init_for_window(self.search_win)
            LayerShell.set_namespace(self.search_win, "spotlight-search")
            LayerShell.set_layer(self.search_win, LayerShell.Layer.OVERLAY)
            # EXCLUSIVE: with a normal list window also mapped, ON_DEMAND can't
            # pull keyboard focus onto the layer surface, so typing/arrows/Esc
            # (all on this window's key controller) would go to the list window
            # instead. EXCLUSIVE forces the seat's keyboard onto the search bar.
            LayerShell.set_keyboard_mode(self.search_win,
                                         LayerShell.KeyboardMode.EXCLUSIVE)
            # anchor top-left; margins in position() do the actual placement.
            # exclusive_zone -1 => margins are from the true output edge (not
            # the waybar-shrunk usable area), so they match the list window's
            # absolute coordinates.
            LayerShell.set_anchor(self.search_win, LayerShell.Edge.TOP, True)
            LayerShell.set_anchor(self.search_win, LayerShell.Edge.LEFT, True)
            LayerShell.set_exclusive_zone(self.search_win, -1)
        self.search_win.connect("notify::is-active", self.on_active)

        search_pill = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        search_pill.add_css_class("pill")
        search_pill.add_css_class("search-pill")
        search_pill.set_size_request(WIDTH, SEARCH_H)
        search_pill.append(make_icon("system-search-symbolic", 20))
        self.entry = Gtk.Entry(hexpand=True)
        self.entry.add_css_class("search-entry")
        self.entry.set_placeholder_text("Search")
        self.entry.connect("changed", self.on_changed)
        self.entry.connect("activate", lambda *_: self.activate_selected())
        search_pill.append(self.entry)
        self.search_win.set_child(search_pill)

        keys = Gtk.EventControllerKey()
        keys.connect("key-pressed", self.on_key)
        self.search_win.add_controller(keys)

        # list window — content panel, grows downward
        self.list_win = Gtk.ApplicationWindow(application=self)
        self.list_win.set_title("spotlight-list")
        self.list_win.set_decorated(False)
        self.list_win.set_resizable(False)
        self.list_win.add_css_class("spotlight")
        self.list_win.set_hide_on_close(True)
        self.list_win.connect("notify::is-active", self.on_active)

        content_pill = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content_pill.add_css_class("pill")
        content_pill.add_css_class("content-pill")
        content_pill.set_size_request(WIDTH, -1)
        self.list_win.set_child(content_pill)

        self.grid = Gtk.FlowBox()
        self.grid.add_css_class("grid")
        self.grid.set_min_children_per_line(GRID_COLS)
        self.grid.set_max_children_per_line(GRID_COLS)
        self.grid.set_selection_mode(Gtk.SelectionMode.NONE)
        self.grid.set_homogeneous(True)
        content_pill.append(self.grid)

        self.scroller = Gtk.ScrolledWindow()
        self.scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.scroller.set_max_content_height(360)
        self.scroller.set_propagate_natural_height(True)
        self.listbox = Gtk.ListBox()
        self.listbox.add_css_class("list")
        self.listbox.set_selection_mode(Gtk.SelectionMode.NONE)
        self.scroller.set_child(self.listbox)
        content_pill.append(self.scroller)

    # ── show / hide / position ───────────────────────────────────────
    def toggle(self):
        self.ensure_windows()
        if self.search_win.get_visible():
            self.hide()
        else:
            self.show()

    def show(self):
        self._was_active = False
        self._closeable = False          # don't close during the open churn
        self.entry.set_text("")
        self.list_win.present()          # present list first…
        self.search_win.present()        # …so search ends up focused + on top
        self.entry.grab_focus()
        self.show_empty()
        GLib.timeout_add(20, self.position)   # place once mapped
        GLib.timeout_add(350, self._arm)      # enable focus-out close after churn

    def _arm(self):
        self._closeable = True
        self.focus_search()          # ensure the entry has focus after the churn
        return False

    def hide(self, *_):
        self._was_active = False
        if self.list_win:
            self.list_win.set_visible(False)
        if self.search_win:
            self.search_win.set_visible(False)

    def position(self):
        try:
            outs = json.loads(subprocess.run(
                ["swaymsg", "-t", "get_outputs"],
                capture_output=True, text=True).stdout)
        except Exception:
            return False
        o = next((x for x in outs if x.get("focused")), outs[0] if outs else None)
        if not o:
            return False
        r = o["rect"]
        mx = (r["width"] - WIDTH) // 2          # centered horizontally
        my = int(r["height"] * TOP_FRAC)        # anchored this far down
        x = r["x"] + mx
        ly = r["y"] + my + SEARCH_H + GAP
        # search bar: layer-shell surface placed by anchors + margins
        if LayerShell is not None:
            mon = self._gdk_monitor(o.get("name"))
            if mon is not None:
                LayerShell.set_monitor(self.search_win, mon)
            LayerShell.set_margin(self.search_win, LayerShell.Edge.LEFT, mx)
            LayerShell.set_margin(self.search_win, LayerShell.Edge.TOP, my)
        else:
            swaymsg(f'[app_id="{APP_ID}" title="spotlight-search"] '
                    f'move absolute position {x} {r["y"] + my}')
        # list: normal window, moved directly below the search bar
        swaymsg(f'[app_id="{APP_ID}" title="spotlight-list"] '
                f'move absolute position {x} {ly}')
        self.focus_search()
        return False    # one-shot

    def _gdk_monitor(self, name):
        if not name:
            return None
        mons = Gdk.Display.get_default().get_monitors()
        for i in range(mons.get_n_items()):
            m = mons.get_item(i)
            if m.get_connector() == name:
                return m
        return None

    def focus_search(self):
        # a layer surface isn't addressable by swaymsg title; re-present it so
        # gtk4-layer-shell requests keyboard focus (ON_DEMAND) away from the
        # normal list window, then focus the entry widget inside it
        if LayerShell is None:
            swaymsg(f'[app_id="{APP_ID}" title="spotlight-search"] focus')
        else:
            self.search_win.present()
        self.entry.grab_focus()

    def _any_active(self):
        return ((self.search_win and self.search_win.is_active()) or
                (self.list_win and self.list_win.is_active()))

    def on_active(self, *_):
        if self._any_active():
            self._was_active = True
        else:
            # focus may just be moving to the OTHER launcher window — defer the
            # close check so landing on the sibling cancels it
            GLib.timeout_add(120, self._check_close)

    def _check_close(self):
        if (FOCUS_OUT_CLOSE and self._closeable and self._was_active
                and not self._any_active()
                and self.search_win.get_visible()):
            self.hide()
        return False

    # ── rendering ────────────────────────────────────────────────────
    def clear(self, box):
        child = box.get_first_child()
        while child is not None:
            nxt = child.get_next_sibling()
            box.remove(child)
            child = nxt

    def show_empty(self):
        items = elephant("desktopapplications", "", GRID_COLS * GRID_ROWS)
        self.clear(self.grid)
        self.cells = []
        for it in items:
            cell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
            cell.add_css_class("cell")
            cell.append(make_icon(it["icon"], 44))
            lbl = Gtk.Label(label=it["text"])
            lbl.add_css_class("cell-label")
            lbl.set_ellipsize(3)
            lbl.set_max_width_chars(11)
            cell.append(lbl)
            self.arm_click(cell, len(self.cells))
            self.grid.append(cell)
            self.cells.append((cell, it))
        self.grid.set_visible(True)
        self.scroller.set_visible(False)
        self.select(0)

    def show_list(self, items):
        self.clear(self.listbox)
        self.cells = []
        for it in items:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.add_css_class("row")
            row.append(make_icon(it["icon"], it.get("icon_px") or 30))
            texts = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, hexpand=True)
            texts.set_valign(Gtk.Align.CENTER)
            t = Gtk.Label(label=it["text"], xalign=0, hexpand=True)
            t.add_css_class("row-title")
            t.set_ellipsize(3)
            texts.append(t)
            if it["subtext"]:
                s = Gtk.Label(label=it["subtext"], xalign=0, hexpand=True)
                s.add_css_class("row-subtext")
                s.set_ellipsize(3)
                texts.append(s)
            row.append(texts)
            self.arm_click(row, len(self.cells))
            self.listbox.append(row)
            self.cells.append((row, it))
        self.grid.set_visible(False)
        self.scroller.set_visible(True)
        self.select(0)

    def arm_click(self, widget, index):
        click = Gtk.GestureClick()
        click.connect("released", lambda *_: (self.select(index),
                                              self.activate_selected()))
        widget.add_controller(click)
        motion = Gtk.EventControllerMotion()
        motion.connect("enter", lambda *_: self.select(index))
        widget.add_controller(motion)

    # ── selection / activation ───────────────────────────────────────
    def select(self, i):
        if not self.cells:
            self.sel = 0
            return
        self.sel = max(0, min(i, len(self.cells) - 1))
        for n, (w, _) in enumerate(self.cells):
            (w.add_css_class if n == self.sel else w.remove_css_class)("selected")

    def activate_selected(self):
        if not self.cells:
            return
        it = self.cells[self.sel][1]
        kind, val = it["kind"], it["value"]
        if kind == "fill":
            self.entry.set_text(val)
            self.entry.set_position(-1)
            return
        if kind == "noop":
            return
        if kind == "calc":
            subprocess.run(["wl-copy", val])
        elif kind == "cmd":
            self._spawn(["/bin/sh", "-c", val])
        else:
            self._spawn(["gtk-launch", val])
        self.hide()

    def _spawn(self, argv):
        # Popen'd children of this long-running daemon become zombies once
        # they exit unless something reaps them — GLib's child watch does
        # that (and a zombie still matches e.g. `pgrep`, which broke the
        # "already running?" check other scripts use to avoid duplicates).
        #
        # Our own LD_PRELOAD (gtk4-layer-shell, set by the systemd unit so
        # THIS process can be a true-capsule layer surface) is inherited by
        # every child otherwise — and hard-crashes any GTK3 app it hooks
        # into GTK-init-order-wise (confirmed: nwg-displays segfaults with
        # "gdk_display_manager_get() was called before gtk_init()"). Children
        # don't need it, so strip it.
        env = os.environ.copy()
        env.pop("LD_PRELOAD", None)
        proc = subprocess.Popen(argv, start_new_session=True, env=env)
        GLib.child_watch_add(proc.pid, lambda pid, status: None)

    # ── search / commands ────────────────────────────────────────────
    def on_changed(self, entry):
        text = entry.get_text()
        if text == "":
            self.show_empty()
            return
        if text.startswith("/"):
            head, sep, arg = text.partition(" ")
            if head in COMMANDS:
                self.show_list(COMMANDS[head](arg if sep else ""))
            else:
                sugg = [item(c, "command", "utilities-terminal", "fill", c + " ")
                        for c in COMMANDS if c.startswith(head)]
                self.show_list(sugg or [item("No such command", "", "dialog-error",
                                             "noop", "")])
            return
        self.show_list(elephant("desktopapplications,calc", text, LIST_LIMIT))

    def on_key(self, controller, keyval, keycode, state):
        if keyval == Gdk.KEY_Escape:
            self.hide()
            return True
        if keyval in (Gdk.KEY_Down, Gdk.KEY_Up, Gdk.KEY_Left, Gdk.KEY_Right):
            if self.grid.get_visible():
                step = {Gdk.KEY_Right: 1, Gdk.KEY_Left: -1,
                        Gdk.KEY_Down: GRID_COLS, Gdk.KEY_Up: -GRID_COLS}[keyval]
            else:
                if keyval in (Gdk.KEY_Left, Gdk.KEY_Right):
                    return True
                step = 1 if keyval == Gdk.KEY_Down else -1
            self.select(self.sel + step)
            return True
        return False

    # ── css ──────────────────────────────────────────────────────────
    def load_css(self):
        display = Gdk.Display.get_default()
        # drop previously-loaded providers so a reload actually swaps the colors
        for old in self._css_providers:
            Gtk.StyleContext.remove_provider_for_display(display, old)
        self._css_providers = []
        for fname, prio in (("colors.css", Gtk.STYLE_PROVIDER_PRIORITY_USER),
                            ("style.css", Gtk.STYLE_PROVIDER_PRIORITY_USER + 1)):
            path = os.path.join(CONFIG, fname)
            if not os.path.exists(path):
                continue
            provider = Gtk.CssProvider()
            provider.load_from_path(path)
            Gtk.StyleContext.add_provider_for_display(display, provider, prio)
            self._css_providers.append(provider)


if __name__ == "__main__":
    sys.exit(Spotlight().run(sys.argv))
