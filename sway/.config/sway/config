# ── armojidots · SwayFX ─────────────────────────────
# Entry point: shared variables + module includes.
# Each concern lives in its own file — add features by
# editing (or adding) a module, not by touching others.

# Shared variables (used by all modules)
set $mod Mod4
set $term foot
set $files nemo

# Modules
include ~/.config/sway/keybinds.conf
include ~/.config/sway/workspaces.conf
include ~/.config/sway/appearance.conf
include ~/.config/sway/effects.conf
include ~/.config/sway/autostart.conf
