# ── armojidots · SwayFX ─────────────────────────────
# Entry point: shared variables + module includes.
# Each concern lives in its own file — add features by
# editing (or adding) a module, not by touching others.

# Shared variables (used by all modules)
set $mod Mod4
set $term foot
set $files nemo
set $browser zen-browser

# Monitor layout (resolution, position, scale, refresh rate). Generated by
# nwg-displays (/set monitors) — not present until you actually save a
# layout there once; sway tolerates a missing include, so this is safe
# on a fresh install too.
include ~/.config/sway/outputs
include ~/.config/sway/workspaces

# Modules
include ~/.config/sway/input.conf
include ~/.config/sway/keybinds.conf
include ~/.config/sway/media-keys.conf
include ~/.config/sway/workspaces.conf
include ~/.config/sway/appearance.conf
include ~/.config/sway/effects.conf
include ~/.config/sway/animations.conf
include ~/.config/sway/rules.conf
include ~/.config/sway/autostart.conf
